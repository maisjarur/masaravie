# Server
PORT=3000
NODE_ENV=development

# Geoapify — https://www.geoapify.com (3,000 free req/day)
GEOAPIFY_API_KEY=

# CORS — set to your frontend origin in production (e.g. https://masaravie.com)
ALLOWED_ORIGIN=

# Agent API Keys — comma-separated keys for AI agent access
AGENT_API_KEYS=

# Optional: Apify token (for future Instagram scraping)
APIFY_TOKEN=
